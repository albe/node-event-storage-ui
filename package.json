{
  "name": "event-storage-ui",
  "version": "1.0.0-alpha.1",
  "description": "A simple UI for node event-storage",
  "type": "module",
  "main": "index.js",
  "keywords": [
    "event-storage",
    "event-sourcing",
    "eventstore",
    "domain events",
    "embedded",
    "append-only",
    "cqrs",
    "log storage",
    "admin-ui"
  ],
  "homepage": "https://github.com/albe/node-event-storage-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albe/node-event-storage-ui.git"
  },
  "bugs": {
    "url": "https://github.com/albe/node-event-storage-ui/issues"
  },
  "author": "Alexander Berl",
  "license": "MIT",
  "maintainers": [
    {
      "name": "Alexander Berl",
      "email": "a.berl@outlook.com"
    }
  ],
  "engines": {
    "node": ">=18.0"
  },
  "files": [
    "app/",
    "helpers/",
    "projections/",
    "public/.well-known/",
    "public/assets/",
    "public/favicon.ico",
    "public/logo_color.png",
    "public/logo_white.png",
    "public/nodejs-icon.png",
    "eventstore.config.json",
    "eventstore.js",
    "vite.config.js",
    "README.md"
  ],
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "cypress:run": "npm run cypress:functional",
    "cypress:functional": "cypress run --spec \"cypress/e2e/functional/**/*.cy.js\"",
    "cypress:screenshots": "cypress run --spec \"cypress/e2e/screenshots/**/*.cy.js\"",
    "screenshots:sync": "node scripts/update-readme-screenshots.mjs",
    "cypress:screenshots:readme": "cypress run --spec cypress/e2e/screenshots/readme.screenshots.cy.js && npm run screenshots:sync",
    "cypress:run:all": "cypress run",
    "cypress:open": "cypress open"
  },
  "dependencies": {
    "@fontsource/material-icons": "^5.2.7",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/roboto-slab": "^5.2.8",
    "@react-router/fs-routes": "^7.15.0",
    "@react-router/node": "^7.15.0",
    "@react-router/serve": "^7.15.0",
    "adminator-admin-dashboard": "^4.1.5",
    "chart.js": "^4.5.1",
    "font-awesome": "^4.7.0",
    "material-dashboard-dark-edition": "^2.1.0",
    "react": "19.2.6",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "19.2.6",
    "react-router": "^7.15.0",
    "react18-json-view": "^0.2.10",
    "systeminformation": "^5.31.6"
  },
  "peerDependencies": {
    "event-storage": "^1.2.0"
  },
  "devDependencies": {
    "@react-router/dev": "^7.15.0",
    "cypress": "^15.16.0",
    "event-storage": "^1.2.0",
    "postcss": "^8.5.14",
    "sass-embedded": "^1.99.0",
    "vite": "^8.0.14"
  }
}
