{
  "name": "event-storage-ui",
  "version": "1.0.1",
  "description": "A simple UI for node event-storage",
  "type": "module",
  "main": "build/server/index.js",
  "bin": {
    "event-storage-ui": "bin/event-storage-ui.js"
  },
  "keywords": [
    "event-storage",
    "event-sourcing",
    "eventstore",
    "domain events",
    "embedded",
    "append-only",
    "cqrs",
    "log storage",
    "admin-ui"
  ],
  "homepage": "https://github.com/albe/node-event-storage-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albe/node-event-storage-ui.git"
  },
  "bugs": {
    "url": "https://github.com/albe/node-event-storage-ui/issues"
  },
  "author": "Alexander Berl",
  "license": "MIT",
  "maintainers": [
    {
      "name": "Alexander Berl",
      "email": "a.berl@outlook.com"
    }
  ],
  "engines": {
    "node": ">=18.0"
  },
  "files": [
    "app/",
    "bin/",
    "helpers/",
    "projections/",
    "public/.well-known/",
    "public/assets/",
    "public/favicon.ico",
    "public/icon-hero-variant-1.svg",
    "public/icon-hero-variant-3.svg",
    "public/icon-spinner-loading.svg",
    "public/icon.svg",
    "public/logo_color.png",
    "public/logo_color.svg",
    "public/logo_white.png",
    "public/logo_white.svg",
    "public/nodejs-icon.png",
    "build/client/.vite/",
    "build/client/assets/",
    "build/client/favicon.ico",
    "build/client/icon-hero-variant-1.svg",
    "build/client/icon-hero-variant-3.svg",
    "build/client/icon-spinner-loading.svg",
    "build/client/icon.svg",
    "build/client/logo_color.png",
    "build/client/logo_color.svg",
    "build/client/logo_white.png",
    "build/client/logo_white.svg",
    "build/client/nodejs-icon.png",
    "build/server/.vite/",
    "build/server/assets/",
    "build/server/index.js",
    "build/eventstore.config.json",
    "config.js",
    "scripts/copy-build-config.mjs",
    "eventstore.config.json",
    "eventstore.js",
    "vite.config.js",
    "README.md"
  ],
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build && node scripts/copy-build-config.mjs",
    "prepack": "npm run build",
    "start": "node ./bin/event-storage-ui.js",
    "test": "mocha test/*.test.js --timeout 15000",
    "cypress:run": "npm run cypress:functional",
    "cypress:functional": "cypress run --spec \"cypress/e2e/functional/**/*.cy.js\"",
    "cypress:screenshots": "cypress run --spec \"cypress/e2e/screenshots/**/*.cy.js\"",
    "screenshots:sync": "node scripts/update-readme-screenshots.mjs",
    "cypress:screenshots:readme": "cypress run --spec cypress/e2e/screenshots/readme.screenshots.cy.js && npm run screenshots:sync",
    "cypress:run:all": "cypress run",
    "cypress:open": "cypress open"
  },
  "dependencies": {
    "@react-router/node": "^7.15.0",
    "@react-router/serve": "^7.15.0",
    "isbot": "^5.1.11",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "^7.15.0",
    "react-select": "^5.10.2",
    "react18-json-view": "^0.2.10",
    "systeminformation": "^5.31.6"
  },
  "peerDependencies": {
    "event-storage": "^1.3.0"
  },
  "devDependencies": {
    "@fontsource/material-icons": "^5.2.7",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/roboto-slab": "^5.2.8",
    "@react-router/dev": "^7.15.0",
    "@react-router/fs-routes": "^7.15.0",
    "adminator-admin-dashboard": "^4.1.5",
    "chart.js": "^4.5.1",
    "cypress": "^15.16.0",
    "event-storage": "^1.3.0",
    "expect.js": "^0.3.1",
    "material-dashboard-dark-edition": "^2.1.0",
    "mocha": "^11.7.6",
    "postcss": "^8.5.14",
    "react-chartjs-2": "^5.3.0",
    "sass-embedded": "^1.99.0",
    "vite": "^8.0.16"
  }
}
